# ============================================================
# Allergy Alert — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Azure AD B2C (public — exposed to browser) ---
# Tenant name: found in Azure Portal > Azure AD B2C > Overview
NEXT_PUBLIC_AZURE_AD_B2C_TENANT_NAME=your-tenant

# Client ID: found in Azure Portal > Azure AD B2C > App registrations > your app > Application (client) ID
NEXT_PUBLIC_AZURE_AD_B2C_CLIENT_ID=your-client-id

# Policy name: the user flow name created in Azure AD B2C (e.g., B2C_1_signup_signin)
NEXT_PUBLIC_AZURE_AD_B2C_POLICY_NAME=B2C_1_signup_signin

# --- Azure Cosmos DB (server-side only — never exposed to browser) ---
# Endpoint: found in Azure Portal > Cosmos DB account > Keys > URI
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/

# Primary Key: found in Azure Portal > Cosmos DB account > Keys > PRIMARY KEY
AZURE_COSMOS_KEY=your-primary-key

# Database name (default: allergy-alert)
AZURE_COSMOS_DATABASE=allergy-alert

# --- Azure AI Foundry (server-side only — never exposed to browser) ---
# Endpoint: found in Azure AI Foundry > your deployment > Endpoint URL
AZURE_AI_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/

# API Key: found in Azure AI Foundry > your deployment > Keys
AZURE_AI_FOUNDRY_API_KEY=your-api-key

# Model/deployment name (e.g., gpt-4, gpt-35-turbo)
AZURE_AI_FOUNDRY_MODEL_NAME=gpt-4
